# target/
# Ignore everything under `target/` except `invoicingTool.jar`
/target/*
!/target/invoicingTool.jar
/target/original-InvoicingTool.jar
!.mvn/wrapper/maven-wrapper.jar
!**/src/main/**/target/
!**/src/test/**/target/
/target/classes/
/target/generated-sources/
/target/generated-test-sources/
/target/maven-archiver/
/target/test-classes/
/target/maven-status/


